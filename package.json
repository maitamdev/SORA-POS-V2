{
  "name": "sora-pos-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend && npx shx rm -rf dist && npx shx mv frontend/dist dist"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "shx": "^0.4.0"
  }
}
